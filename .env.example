# BonsaiChat — environment configuration
# Copy this file to .env and edit as needed.
# BonsaiChat is 100% local — no cloud API keys required.

# ── Model download (optional overrides) ──────────────────────────────────
# Override these if you want to use a different GGUF model from Hugging Face.
# The defaults point to a small, fast quantised model for first-time users.
# BONSAI_HF_REPO=HuggingFaceTB/smollm2-1.7b-instruct-GGUF
# BONSAI_HF_FILE=smollm2-1.7b-instruct-q4_k_m.gguf

# ── llama-server port (optional) ─────────────────────────────────────────
# Change if 8081 is already in use on your machine.
# LLAMA_PORT=8081
